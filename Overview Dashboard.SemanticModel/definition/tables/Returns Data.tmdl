		lineageTag: aa11c173-a576-4558-a706-b0f45202d73d
		summarizeBy: none
		sourceColumn: ProductKey

		annotation SummarizationSetBy = Automatic

	column ReturnQuantity
		dataType: int64
		formatString: 0
		lineageTag: 2f64878a-9168-4ae5-849e-35f590c3b14e
		summarizeBy: sum
		sourceColumn: ReturnQuantity

		annotation SummarizationSetBy = Automatic

