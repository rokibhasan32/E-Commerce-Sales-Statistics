table 'Returns Data'
	lineageTag: a37dc88c-a442-4486-b0f9-10a6a0be1e83

	measure 'Total Value of Returns' = SUMX('Returns Data', 'Returns Data'[ReturnQuantity] * RELATED('Product Lookup'[ProductPrice]))
		lineageTag: 4aa78e3e-3954-449a-9165-9c8f38fd09ad

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Return Cost Impact' = SUMX('Returns Data', 'Returns Data'[ReturnQuantity] * RELATED('Product Lookup'[ProductCost]))
		lineageTag: b394894e-9334-46b8-8607-33d1db9bbcfb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Profit Loss' = [Total Value of Returns] - [Return Cost Impact]
		lineageTag: faf1f276-9d3e-426e-af13-edd6a9d21b17

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Profit' = [Gross Profit] - [Net Profit Loss]
		lineageTag: ea2390cf-1140-4ed0-83df-5120d3163bea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column ReturnDate
		dataType: dateTime
