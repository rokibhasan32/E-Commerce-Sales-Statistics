	partition Dim_Date = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    // 1. Generate the continuous list of dates based on your Fact table
				    CALENDAR ( MIN('Fact_Sales'[OrderDate]), MAX('Fact_Sales'[OrderDate]) ),
				    
				    // 2. Add useful columns for filtering and formatting
				    "Year", YEAR ( [Date] ),
				    "Quarter Number", QUARTER ( [Date] ),
				    "Quarter", "Q" & QUARTER ( [Date] ),
				    "Month Number", MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMMM" ),
				    "Month Short Name", FORMAT ( [Date], "MMM" ),
				    "Day of Month", DAY ( [Date] ),
				    "Day of Week Number", WEEKDAY ( [Date], 2 ), // 2 sets Monday as day 1 and Sunday as day 7
				    "Day of Week Name", FORMAT ( [Date], "DDDD" ),
				    "Year-Month", FORMAT ( [Date], "YYYY-MM" ),
				    "Year-Quarter", YEAR ( [Date] ) & "-Q" & QUARTER ( [Date] )
				)
				```

	annotation PBI_Id = 4249db5c161844c380e55f4e60593af0

